{
  "name": "hono-nextjs",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "fmt": "oxfmt --check",
    "fmt:fix": "oxfmt",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "prisma:generate": "pnpm --filter database prisma:generate",
    "prisma:migrate:dev": "pnpm --filter database prisma:migrate:dev",
    "start": "pnpm --filter web start",
    "type-check": "turbo run type-check"
  },
  "devDependencies": {
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": "24.14.0"
  },
  "packageManager": "pnpm@10.32.1"
}
