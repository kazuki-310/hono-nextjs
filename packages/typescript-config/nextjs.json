{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "ESNext"],
    "noEmit": true,
    "incremental": true,
    "jsx": "preserve",
    "forceConsistentCasingInFileNames": true,
    "plugins": [{ "name": "next" }]
  }
}
